#!/bin/sh
# Control-plane drift gate: block commits if the structural doctor or scope gate fails.
# CI (.github/workflows/control-plane.yml) becomes the authoritative gate once a GitHub
# remote + branch protection exist (roadmap/risks/R-001); until then this is the enforcement.
if command -v python >/dev/null 2>&1; then PY=python
elif command -v python3 >/dev/null 2>&1; then PY=python3
else echo "pre-commit: python not found; skipping control-plane gates" >&2; exit 0; fi

if [ -f roadmap/tools/doctor.py ]; then
  "$PY" roadmap/tools/doctor.py || {
    echo "" >&2
    echo "Commit blocked: control-plane doctor found drift (see above)." >&2
    echo "Fix roadmap/ consistency. Agents: halt and report -- never bypass." >&2
    echo "(Human owner only, once, with cause: git commit --no-verify)" >&2
    exit 1
  }
fi

if [ -f roadmap/tools/scope_gate.py ]; then
  "$PY" roadmap/tools/scope_gate.py || exit 1
fi
exit 0
